{
  "name": "game-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cross-env GAME_OS_NEXT_DIST_DIR=.next-dev NODE_OPTIONS=--disable-warning=ExperimentalWarning next dev",
    "dev:fresh": "npm run clean && npm run dev",
    "build": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning next build",
    "start": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning next start",
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['.next','.next-dev']) fs.rmSync(dir,{recursive:true,force:true})\"",
    "test": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest",
    "smoke": "node scripts/smoke-local.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs",
    "check": "npm test && npm run build && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "cross-env": "^7.0.3",
    "playwright-core": "^1.60.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
